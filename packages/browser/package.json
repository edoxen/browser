{
  "name": "@edoxen/browser",
  "version": "0.7.0",
  "description": "Astro-based browser for edoxen YAML data — drop in your data and ship a resolutions archive site.",
  "type": "module",
  "license": "BSD-2-Clause",
  "author": "Edoxen Project contributors",
  "homepage": "https://github.com/edoxen/browser",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edoxen/browser.git",
    "directory": "packages/browser"
  },
  "bugs": {
    "url": "https://github.com/edoxen/browser/issues"
  },
  "keywords": [
    "astro",
    "edoxen",
    "resolutions",
    "standards",
    "iso",
    "oiml"
  ],
  "sideEffects": [
    "./src/islands/**/*.ts",
    "./src/islands/**/*.js",
    "*.css"
  ],
  "bin": {
    "edoxen-browser": "./dist/cli.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config/index.ts",
    "./data": "./src/data/index.ts",
    "./seo": "./src/seo/index.ts",
    "./i18n": "./src/i18n/index.ts",
    "./integration": "./src/integration.ts",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src/",
    "styles/",
    "dist/cli.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:cli": "tsup",
    "prepublishOnly": "pnpm build:cli",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "pretest:e2e": "pnpm build:cli",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@astrojs/vue": "^5.0.0",
    "@edoxen/edoxen": "^0.2.3",
    "@tailwindcss/vite": "^4.0.0",
    "ajv": "^8.17.0",
    "astro": "^7.0.0",
    "tailwindcss": "^4.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@astrojs/vue": "^5.0.0",
    "@edoxen/edoxen": "^0.2.3",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "ajv": "^8.17.0",
    "astro": "^7.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0",
    "vue": "^3.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@asciidoctor/core": "^3.0.4",
    "@astrojs/sitemap": "^3.7.3",
    "jiti": "^2.4.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  }
}
