---
import type { Statement } from '@edoxen/edoxen'
import { pickLocalizedValue } from '../../i18n/index.js'

interface Props {
  statements: readonly Statement[]
  locale: string
}
const { statements, locale } = Astro.props

const kindLabel: Record<string, string> = {
  statement: 'Statement',
  comment: 'Comment',
  standpoint: 'Standpoint',
}

// Kind chips are soft tints of the shared status tokens, so consumer
// re-theming flows through automatically.
const kindToken: Record<string, string> = {
  statement: 'var(--edoxen-color-accent)',
  comment: 'var(--edoxen-color-muted)',
  standpoint: 'var(--edoxen-color-warning)',
}

function personDisplay(person: { name?: { formatted?: string }[] }): string {
  const names = person?.name
  if (!Array.isArray(names) || names.length === 0) return ''
  const first = names[0]
  if (!first) return ''
  return typeof first === 'object' ? (first.formatted ?? '') : String(first)
}
---

{statements.length > 0 && (
  <ul class="edoxen-statement-list">
    {statements.map((stmt) => (
      <li class="edoxen-statement-list__item">
        <div class="edoxen-statement-list__head">
          {stmt.kind && (
            <span
              class="edoxen-statement-list__kind"
              style={`--_kind:${kindToken[stmt.kind] ?? kindToken.statement}`}
            >
              {kindLabel[stmt.kind] ?? stmt.kind}
            </span>
          )}
          {(stmt.party ?? []).length > 0 && (
            <span class="edoxen-statement-list__party">
              {(stmt.party ?? []).map(personDisplay).filter(Boolean).join(', ')}
            </span>
          )}
        </div>
        <p class="edoxen-statement-list__text">{pickLocalizedValue(stmt.description, locale)}</p>
      </li>
    ))}
  </ul>
)}

<style>
.edoxen-statement-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.875rem;
}
.edoxen-statement-list__item {
  border-left: 2px solid var(--edoxen-color-border);
  padding: 0.125rem 0 0.125rem 0.875rem;
}
.edoxen-statement-list__head {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.25rem;
}
.edoxen-statement-list__kind {
  display: inline-flex;
  align-items: center;
  padding: 0.0625rem 0.5rem;
  border-radius: 9999px;
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  color: var(--_kind, var(--edoxen-color-muted));
  background: color-mix(in srgb, var(--_kind, var(--edoxen-color-muted)) 12%, transparent);
  border: 1px solid color-mix(in srgb, var(--_kind, var(--edoxen-color-muted)) 30%, transparent);
}
.edoxen-statement-list__party {
  font-size: 0.75rem;
  color: var(--edoxen-color-muted);
}
.edoxen-statement-list__text {
  margin: 0;
  font-size: 0.9375rem;
  color: var(--edoxen-color-text);
}
</style>
