---
import { actionTypeColor, actionTypeLabel } from '@edoxen/edoxen'

interface Props {
  kind: string
}
const { kind } = Astro.props
const color = actionTypeColor(kind)
const label = actionTypeLabel(kind)
const style = color ? `background:${color};color:#fff` : undefined
---

{kind && (
  <span class="edoxen-action-badge" style={style}>{label}</span>
)}

<style>
.edoxen-action-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  padding: 0.125rem 0.625rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 600;
  line-height: 1.6;
  letter-spacing: 0.01em;
  white-space: nowrap;
  text-transform: capitalize;
  background: var(--edoxen-color-muted);
  color: #fff;
  background: color-mix(in srgb, var(--edoxen-color-muted) 13%, transparent);
  color: var(--edoxen-color-text);
  border: 1px solid color-mix(in srgb, var(--edoxen-color-muted) 28%, transparent);
}
</style>
