---
import { urnToPath } from '../../urn.js'

interface Props {
  prev?: { urn: string; title: string }
  next?: { urn: string; title: string }
  basePath: string
}
const { prev, next, basePath } = Astro.props
---

{(prev || next) && (
  <nav class="edoxen-prev-next" aria-label="Adjacent items">
    <div class="edoxen-prev-next__cell">
      {prev && (
        <a href={`${basePath}/${urnToPath(prev.urn)}`} rel="prev">
          <span class="edoxen-prev-next__label">← Previous</span>
          <span class="edoxen-prev-next__title">{prev.title}</span>
        </a>
      )}
    </div>
    <div class="edoxen-prev-next__cell edoxen-prev-next__cell--right">
      {next && (
        <a href={`${basePath}/${urnToPath(next.urn)}`} rel="next">
          <span class="edoxen-prev-next__label">Next →</span>
          <span class="edoxen-prev-next__title">{next.title}</span>
        </a>
      )}
    </div>
  </nav>
)}

<style>
.edoxen-prev-next {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-top: 2.5rem;
  padding-top: 1.25rem;
  border-top: 1px solid var(--edoxen-color-border);
}
.edoxen-prev-next__cell--right {
  text-align: right;
}
.edoxen-prev-next__cell a {
  display: flex;
  flex-direction: column;
  gap: 0.125rem;
  text-decoration: none;
  padding: 0.625rem 0.875rem;
  border: 1px solid var(--edoxen-color-border);
  border-radius: var(--edoxen-radius-sm);
  background: var(--edoxen-color-surface);
  box-shadow: var(--edoxen-shadow-sm, 0 1px 2px rgb(28 25 23 / 0.05));
  transition: border-color 150ms ease, box-shadow 150ms ease,
    transform 150ms ease;
}
.edoxen-prev-next__cell a:hover {
  border-color: color-mix(in srgb, var(--edoxen-color-accent) 55%, var(--edoxen-color-border));
  box-shadow: var(--edoxen-shadow-md, 0 4px 12px rgb(28 25 23 / 0.08));
  transform: translateY(-1px);
  text-decoration: none;
}
.edoxen-prev-next__label {
  font-size: 0.6875rem;
  font-weight: 600;
  color: var(--edoxen-color-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.edoxen-prev-next__title {
  font-family: var(--edoxen-font-display-resolved, "Iowan Old Style",
    "Palatino Linotype", Palatino, Georgia, "Times New Roman", serif);
  font-weight: 600;
  color: var(--edoxen-color-primary);
}
</style>
