---
import type { Minutes } from '@edoxen/edoxen'
import { pickLocalizedValue } from '../../i18n/index.js'
import StatementList from './StatementList.astro'
interface Props { minutes: Minutes; locale: string }
const { minutes, locale } = Astro.props
const sections = minutes.sections ?? []
const spelling = minutes.spelling ?? locale
---
<article class="border border-border rounded-sm p-4 px-5 bg-surface mb-4" data-spelling={spelling}>
  <header>
    <h3 class="m-0 mb-2 text-base">Minutes{spelling ? ` — ${spelling}` : ''}</h3>
    {minutes.urn && <p class="m-0"><code class="font-mono text-xs text-accent">{minutes.urn}</code></p>}
  </header>
  {sections.map((section) => (
    <section class="mt-4">
      <h4 class="m-0 mb-2 text-sm font-semibold">{section.number}. {pickLocalizedValue(section.title, locale, '(untitled)')}</h4>
      <div class="text-sm leading-relaxed whitespace-pre-wrap text-text">
        {pickLocalizedValue(section.narrative, locale)}
      </div>
      {(section.statements ?? []).length > 0 && (
        <div class="mt-3">
          <h5 class="m-0 mb-1.5 text-xs font-semibold uppercase tracking-wide text-muted">Statements</h5>
          <StatementList statements={section.statements ?? []} locale={locale} />
        </div>
      )}
    </section>
  ))}
</article>
