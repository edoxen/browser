---
import cfg from 'virtual:edoxen-config'

interface Props {
  code?: string
}
const { code } = Astro.props
const body = code ? cfg.bodies.find((b) => b.code === code) : undefined
const style = body?.color
  ? `background:${body.color};color:${body.textColor ?? '#ffffff'}`
  : undefined
---

{code && (
  <span class="edoxen-badge" style={style}>{body?.name ?? code}</span>
)}

<style>
.edoxen-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  padding: 0.125rem 0.625rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 600;
  line-height: 1.6;
  letter-spacing: 0.01em;
  white-space: nowrap;
  background: var(--edoxen-color-muted);
  color: #fff;
  background: color-mix(in srgb, var(--edoxen-color-muted) 13%, transparent);
  color: var(--edoxen-color-text);
  border: 1px solid color-mix(in srgb, var(--edoxen-color-muted) 28%, transparent);
}
</style>
