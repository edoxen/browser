---
import type { MeetingComponent } from '@edoxen/edoxen'
import { pickLocalizedValue } from '../../i18n/index.js'

interface Props {
  components: readonly MeetingComponent[]
  locale: string
}
const { components, locale } = Astro.props

interface DayGroup {
  date: string
  weekday: string
  label: string
  items: readonly MeetingComponent[]
}

function formatTime(iso: string): string {
  const d = new Date(iso)
  if (Number.isNaN(d.getTime())) return iso
  return d.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false })
}

function formatTz(iso: string): string {
  const match = iso.match(/[+-]\d{2}:?\d{2}$/)
  return match ? `UTC${match[0].slice(0, 3)}` : ''
}

function dayKey(iso: string): string {
  return iso.slice(0, 10)
}

function weekdayName(key: string): string {
  const d = new Date(key + 'T00:00:00')
  if (Number.isNaN(d.getTime())) return ''
  return d.toLocaleDateString('en-US', { weekday: 'long' })
}

function dayLabel(key: string): string {
  const d = new Date(key + 'T00:00:00')
  if (Number.isNaN(d.getTime())) return key
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
}

const scheduled = components
  .filter((c) => c.starts_at)
  .slice()
  .sort((a, b) => (a.starts_at ?? '').localeCompare(b.starts_at ?? ''))

const days: DayGroup[] = []
let currentKey = ''
for (const c of scheduled) {
  const key = dayKey(c.starts_at!)
  if (key !== currentKey) {
    days.push({ date: key, weekday: weekdayName(key), label: dayLabel(key), items: [c] })
    currentKey = key
  } else {
    days[days.length - 1].items.push(c)
  }
}

const tzLabel = scheduled[0]?.starts_at ? formatTz(scheduled[0].starts_at) : ''
---

<div class="edoxen-schedule">
  {days.map((day) => (
    <div class="edoxen-schedule__day">
      <div class="edoxen-schedule__day-head">
        <h3 class="edoxen-schedule__weekday">{day.weekday}</h3>
        <span class="edoxen-schedule__date">{day.label}</span>
      </div>
      <div class="edoxen-schedule__entries">
        {day.items.map((c) => (
          <div class="edoxen-schedule__entry">
            <div class="edoxen-schedule__time">
              <div class="edoxen-schedule__start">{formatTime(c.starts_at!)}</div>
              <div class="edoxen-schedule__end">{formatTime(c.ends_at!)}</div>
            </div>
            <div class="edoxen-schedule__rule" aria-hidden="true"></div>
            <div class="edoxen-schedule__body">
              {c.kind && (
                <span class="edoxen-schedule__kind">{c.kind.replace(/_/g, ' ')}</span>
              )}
              <p class="edoxen-schedule__title">{pickLocalizedValue(c.title, locale, c.identifier ?? '')}</p>
              {c.description && pickLocalizedValue(c.description, locale) && (
                <p class="edoxen-schedule__desc">{pickLocalizedValue(c.description, locale)}</p>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}
  {tzLabel && (
    <p class="edoxen-schedule__tz">All times {tzLabel}</p>
  )}
</div>

<style>
.edoxen-schedule {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}
.edoxen-schedule__day-head {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  margin-bottom: 0.875rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--edoxen-color-border);
}
.edoxen-schedule__weekday {
  margin: 0;
  font-size: 1.25rem;
}
.edoxen-schedule__date {
  font-family: var(--edoxen-font-mono, ui-monospace, monospace);
  font-size: 0.8125rem;
  color: var(--edoxen-color-muted);
  font-variant-numeric: tabular-nums;
}
.edoxen-schedule__entries {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
}
.edoxen-schedule__entry {
  display: flex;
  align-items: stretch;
  gap: 1rem;
  padding: 0.75rem 1rem;
  border: 1px solid var(--edoxen-color-border);
  border-radius: var(--edoxen-radius-sm);
  background: var(--edoxen-color-surface);
  transition: border-color 150ms ease;
}
.edoxen-schedule__entry:hover {
  border-color: color-mix(in srgb, var(--edoxen-color-accent) 55%, var(--edoxen-color-border));
}
.edoxen-schedule__time {
  flex-shrink: 0;
  width: 6rem;
  text-align: right;
  font-family: var(--edoxen-font-mono, ui-monospace, monospace);
  font-variant-numeric: tabular-nums;
}
.edoxen-schedule__start {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--edoxen-color-primary);
}
.edoxen-schedule__end {
  font-size: 0.75rem;
  color: var(--edoxen-color-muted);
}
.edoxen-schedule__rule {
  width: 1px;
  background: var(--edoxen-color-border);
  flex-shrink: 0;
}
.edoxen-schedule__body {
  flex: 1;
  min-width: 0;
}
.edoxen-schedule__kind {
  display: inline-flex;
  align-items: center;
  margin-bottom: 0.25rem;
  padding: 0.0625rem 0.5rem;
  border-radius: 9999px;
  font-size: 0.625rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--edoxen-color-muted);
  background: color-mix(in srgb, var(--edoxen-color-muted) 12%, transparent);
}
.edoxen-schedule__title {
  margin: 0;
  font-family: var(--edoxen-font-display, "Iowan Old Style",
    "Palatino Linotype", Palatino, Georgia, "Times New Roman", serif);
  font-size: 1rem;
  font-weight: 600;
  line-height: 1.35;
  color: var(--edoxen-color-primary);
  max-width: none;
}
.edoxen-schedule__desc {
  margin: 0.25rem 0 0;
  font-size: 0.875rem;
  color: var(--edoxen-color-muted);
}
.edoxen-schedule__tz {
  margin: 0;
  padding-top: 1rem;
  border-top: 1px solid var(--edoxen-color-border);
  text-align: center;
  font-family: var(--edoxen-font-mono, ui-monospace, monospace);
  font-size: 0.75rem;
  color: var(--edoxen-color-muted);
  max-width: none;
}
@media (max-width: 32rem) {
  .edoxen-schedule__entry {
    flex-direction: column;
    gap: 0.375rem;
  }
  .edoxen-schedule__time {
    width: auto;
    text-align: left;
    display: flex;
    gap: 0.5rem;
  }
  .edoxen-schedule__rule {
    display: none;
  }
}
</style>

