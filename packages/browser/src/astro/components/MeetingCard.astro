---
import type { MeetingListItem } from '../../data/index.js'
import { isVirtualMeeting } from '../../data/index.js'
import { pickLocalizedValue, formatDateRange, regionName, t, meetingTypeLabel } from '../../i18n/index.js'
import { urnToPath } from '../../urn.js'
import { countryFlag } from '@edoxen/edoxen'
import cfg from 'virtual:edoxen-config'

interface Props {
  item: MeetingListItem
  lang?: string
  urlPrefix?: string
}
const { item: m, lang = 'en', urlPrefix: prefix = '/' } = Astro.props
const fullTitle = pickLocalizedValue(m.title, lang, m.urn)
const dateLabel = m.startDate ? formatDateRange(m.startDate, m.endDate, lang) : ''
const virtual = isVirtualMeeting(m)
const flag = !virtual && m.countryCode ? countryFlag(m.countryCode) : ''
const city = m.cityNames?.[lang] ?? m.cityNames?.[lang.slice(0, 2)] ?? m.cityNames?.en ?? m.city ?? ''
const country = !virtual && m.countryCode ? regionName(m.countryCode, lang) : ''
const placeLabel = virtual
  ? t('meeting.virtual', lang, cfg.uiStrings, cfg.terminology)
  : [city, country].filter(Boolean).join(', ')
const headline = placeLabel || fullTitle
const typeLabel = meetingTypeLabel(m.type, lang, cfg.terminology, cfg.uiStrings)

// Config-driven meta row. The renderer iterates in the configured order;
// adding a new meta item type = extending the union + adding a renderer
// below (OCP). Items not in the list are hidden.
const metaItems = cfg.components.meetingCard.metaItems
const countLabel = (m.decisionCount != null && m.decisionCount > 0)
  ? `${m.decisionCount} ${t('section.adoptedDecisions', lang, cfg.uiStrings, cfg.terminology)}`
  : ''
---

<li class="edoxen-meeting-card edoxen-card">
  <div class="edoxen-meeting-card__meta edoxen-meta-row">
    {metaItems.map((key) => {
      if (key === 'date' && dateLabel) {
        return <span class="edoxen-meeting-card__date"><time datetime={m.startDate}>{dateLabel}</time></span>
      }
      if (key === 'type' && typeLabel) {
        return <span class="edoxen-meeting-card__type">{typeLabel}</span>
      }
      if (key === 'status' && m.status) {
        return <span class="edoxen-badge edoxen-badge--status" data-status={m.status}>{m.status}</span>
      }
      if (key === 'committee' && m.committeeCode) {
        return <span class="edoxen-meeting-card__committee">{m.committeeCode}</span>
      }
      if (key === 'count' && countLabel) {
        return <span class="edoxen-meeting-card__count">{countLabel}</span>
      }
      return null
    })}
  </div>
  <a class="edoxen-meeting-card__title" href={`${prefix}meetings/${urnToPath(m.urn)}`} title={fullTitle}>
    {virtual && <span class="edoxen-meeting-card__flag" aria-hidden="true">🌐</span>}
    {!virtual && flag && <span class="edoxen-meeting-card__flag" aria-hidden="true">{flag}</span>}
    <span class="edoxen-meeting-card__headline">{headline}</span>
  </a>
</li>

<style>
.edoxen-meeting-card {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
}
.edoxen-meeting-card__meta {
  gap: 0.25rem 0.5rem;
}
.edoxen-meeting-card__date {
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--edoxen-color-text);
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}
.edoxen-meeting-card__type {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  text-transform: uppercase;
  color: var(--edoxen-color-muted);
  white-space: nowrap;
}
.edoxen-meeting-card__committee {
  font-family: var(--edoxen-font-mono, ui-monospace, "SF Mono", Menlo, monospace);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.01em;
  color: var(--edoxen-color-accent);
  padding: 0.125rem 0.5rem;
  border-radius: calc(var(--edoxen-radius-sm) * 0.6);
  border: 1px solid color-mix(in srgb, var(--edoxen-color-accent) 30%, transparent);
}
.edoxen-meeting-card__count {
  margin-left: auto;
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--edoxen-color-muted);
  white-space: nowrap;
}
.edoxen-meeting-card__title {
  display: flex;
  align-items: baseline;
  gap: 0.375rem;
  font-family: var(--edoxen-font-display-resolved, "Iowan Old Style",
    "Palatino Linotype", Palatino, Georgia, "Times New Roman", serif);
  font-size: 1.125rem;
  font-weight: 600;
  line-height: 1.35;
  letter-spacing: -0.01em;
  color: var(--edoxen-color-primary);
}
.edoxen-meeting-card__title:hover,
.edoxen-meeting-card__title:focus-visible {
  color: var(--edoxen-color-accent);
  text-decoration: none;
}
.edoxen-meeting-card__headline {
  flex: 1 1 auto;
}
.edoxen-meeting-card__flag {
  flex: 0 0 auto;
  font-size: 1.1em;
  line-height: 1;
}
</style>
