---
import type { DecisionListItem } from '../../data/index.js'
import { pickLocalizedValue } from '../../i18n/index.js'
import { urnToPath } from '../../urn.js'

interface Props {
  items: readonly DecisionListItem[]
  compact?: boolean
  lang?: string
  urlPrefix?: string
}
const { items, compact = false, lang = 'en', urlPrefix: prefix = '/' } = Astro.props
const listClass = compact ? 'edoxen-decision-list edoxen-decision-list--compact' : 'edoxen-decision-list'
---

{items.length === 0 ? (
  <p class="edoxen-empty">No decisions.</p>
) : (
  <ul class={listClass}>
    {items.map((d) => (
      <li class="edoxen-decision-list__item">
        <a href={`${prefix}decisions/${urnToPath(d.urn)}`}>{pickLocalizedValue(d.title, lang, d.urn)}</a>
        {!compact && (
          <dl class="edoxen-decision-list__meta">
            <dt>URN</dt>
            <dd><code>{d.urn}</code></dd>
            {d.bodyType && <><dt>Body</dt><dd>{d.bodyType}</dd></>}
            {d.kind && <><dt>Kind</dt><dd>{d.kind}</dd></>}
            {d.dates[0]?.date && <><dt>Date</dt><dd>{d.dates[0].date}</dd></>}
          </dl>
        )}
      </li>
    ))}
  </ul>
)}

<style>
.edoxen-decision-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.edoxen-decision-list__item {
  padding: 0.875rem 1.125rem;
  border: 1px solid var(--edoxen-color-border);
  border-radius: var(--edoxen-radius-sm);
  background: var(--edoxen-color-surface);
  box-shadow: var(--edoxen-shadow-sm, 0 1px 2px rgb(28 25 23 / 0.05));
  transition: border-color 150ms ease, box-shadow 150ms ease,
    transform 150ms ease;
}
.edoxen-decision-list__item:hover {
  border-color: color-mix(in srgb, var(--edoxen-color-accent) 55%, var(--edoxen-color-border));
  box-shadow: var(--edoxen-shadow-md, 0 4px 12px rgb(28 25 23 / 0.08));
  transform: translateY(-1px);
}
.edoxen-decision-list__item a {
  font-family: var(--edoxen-font-display, "Iowan Old Style",
    "Palatino Linotype", Palatino, Georgia, "Times New Roman", serif);
  font-size: 1.0625rem;
  font-weight: 600;
  color: var(--edoxen-color-primary);
}
.edoxen-decision-list__item a:hover {
  color: var(--edoxen-color-accent);
  text-decoration: none;
}
.edoxen-decision-list__meta {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 0.25rem 1rem;
  margin: 0.5rem 0 0;
  font-size: 0.8125rem;
  color: var(--edoxen-color-muted);
}
.edoxen-decision-list__meta dd {
  margin: 0;
}
.edoxen-decision-list--compact .edoxen-decision-list__item {
  padding: 0.5rem 0.875rem;
}
</style>
