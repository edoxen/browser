---
import type { DecisionListItem } from '../../data/index.js'
import DecisionCard from './DecisionCard.astro'
import { t } from '../../i18n/index.js'
import cfg from 'virtual:edoxen-config'

interface Props {
  items: readonly DecisionListItem[]
  compact?: boolean
  lang?: string
  urlPrefix?: string
}
const { items, compact = false, lang = 'en', urlPrefix: prefix = '/' } = Astro.props
// Default: responsive card grid (index views). Compact: dense column
// (decisions adopted at a meeting, shown on the meeting detail page).
const listClass = compact
  ? 'edoxen-decision-list edoxen-decision-list--compact'
  : 'edoxen-decision-list edoxen-card-grid'
---

{items.length === 0 ? (
  <p class="edoxen-empty">{t('decisions.empty', lang, cfg.uiStrings, cfg.terminology)}</p>
) : (
  <ul class={listClass}>
    {items.map((d) => (
      <DecisionCard item={d} lang={lang} urlPrefix={prefix} />
    ))}
  </ul>
)}

<style>
.edoxen-decision-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.edoxen-decision-list--compact {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.edoxen-decision-list--compact :global(.edoxen-decision-card) {
  padding: 0.625rem 1rem;
}
.edoxen-decision-list--compact :global(.edoxen-decision-card__snippet) {
  display: none;
}
</style>
