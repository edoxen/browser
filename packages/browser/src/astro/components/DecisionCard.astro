---
import type { DecisionListItem } from '../../data/index.js'
import { pickLocalizedValue, formatDate, humanizeVerb, t } from '../../i18n/index.js'
import { urnToPath } from '../../urn.js'
import cfg from 'virtual:edoxen-config'

interface Props {
  item: DecisionListItem
  lang?: string
  urlPrefix?: string
}
const { item: d, lang = 'en', urlPrefix: prefix = '/' } = Astro.props
const title = pickLocalizedValue(d.title, lang, d.urn)
const subject = pickLocalizedValue(d.subject, lang)
const snippet = pickLocalizedValue(d.snippet, lang)
---

<li class="edoxen-decision-card edoxen-card">
  <div class="edoxen-decision-card__meta edoxen-meta-row">
    {d.identifier && <span class="edoxen-decision-card__id">{d.identifier}</span>}
    {d.kind && <span class="edoxen-badge">{d.kind}</span>}
    {d.actionTypes.slice(0, 3).map((a) => (
      <span class="edoxen-badge edoxen-badge--action">{humanizeVerb(a)}</span>
    ))}
    {d.date && (
      <span class="edoxen-decision-card__date">
        <time datetime={d.date}>{formatDate(d.date, lang)}</time>
      </span>
    )}
    {d.meetingPageUrn && (
      <a class="edoxen-decision-card__meeting" href={`${prefix}meetings/${urnToPath(d.meetingPageUrn)}`}>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        {t('label.meeting', lang, cfg.uiStrings)}
      </a>
    )}
  </div>
  <a class="edoxen-decision-card__title" href={`${prefix}decisions/${urnToPath(d.urn)}`}>{title}</a>
  {subject && <p class="edoxen-decision-card__subject">{subject}</p>}
  {snippet && <p class="edoxen-decision-card__snippet edoxen-snippet">{snippet}</p>}
</li>

<style>
.edoxen-decision-card {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
}
.edoxen-decision-card__meta {
  gap: 0.25rem 0.5rem;
}
.edoxen-decision-card__id {
  font-family: var(--edoxen-font-mono, ui-monospace, "SF Mono", Menlo, monospace);
  font-size: 0.75rem;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.01em;
  color: var(--edoxen-color-muted);
  padding: 0.125rem 0.375rem;
  border-radius: calc(var(--edoxen-radius-sm) * 0.6);
  background: color-mix(in srgb, var(--edoxen-color-text) 5%, transparent);
}
.edoxen-decision-card__date {
  font-size: 0.75rem;
  color: var(--edoxen-color-muted);
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
  padding: 0.125rem 0.25rem;
}
.edoxen-decision-card__meeting {
  margin-left: auto;
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  padding: 0.125rem 0.625rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--edoxen-color-accent);
  border: 1px solid color-mix(in srgb, var(--edoxen-color-accent) 30%, transparent);
  text-decoration: none;
  transition: color 150ms ease, background-color 150ms ease;
}
.edoxen-decision-card__meeting:hover,
.edoxen-decision-card__meeting:focus-visible {
  background: var(--edoxen-color-accent);
  color: var(--edoxen-color-background);
  text-decoration: none;
}
.edoxen-decision-card__title {
  font-family: var(--edoxen-font-display-resolved, "Iowan Old Style",
    "Palatino Linotype", Palatino, Georgia, "Times New Roman", serif);
  font-size: 1.125rem;
  font-weight: 600;
  line-height: 1.35;
  letter-spacing: -0.01em;
  color: var(--edoxen-color-primary);
}
.edoxen-decision-card__title:hover,
.edoxen-decision-card__title:focus-visible {
  color: var(--edoxen-color-accent);
  text-decoration: none;
}
.edoxen-decision-card__subject {
  margin: 0;
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--edoxen-color-muted);
}
.edoxen-decision-card__snippet {
  margin: 0;
  font-size: 0.9375rem;
  line-height: 1.6;
  color: var(--edoxen-color-text);
}
</style>
