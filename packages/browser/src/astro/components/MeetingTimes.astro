---
interface DateRangeLike {
  start?: string
  end?: string
}

interface Props {
  scheduled?: DateRangeLike
  occurred?: DateRangeLike
}

const { scheduled, occurred } = Astro.props

function fmtDate(s?: string): string {
  if (!s) return ''
  return s
}

function fmtDateTime(s?: string): string {
  if (!s) return ''
  return s
}

function hasRange(r?: DateRangeLike): boolean {
  return Boolean(r && (r.start || r.end))
}
---

{hasRange(scheduled) || hasRange(occurred) ? (
  <dl class="edoxen-meeting-times">
    {hasRange(scheduled) && (
      <div class="edoxen-meeting-times__cell">
        <dt>Scheduled</dt>
        <dd>
          <time datetime={scheduled!.start}>{fmtDate(scheduled!.start)}</time>
          {scheduled!.start && scheduled!.end ? ' – ' : ''}
          <time datetime={scheduled!.end}>{fmtDate(scheduled!.end)}</time>
        </dd>
      </div>
    )}
    {hasRange(occurred) && (
      <div class="edoxen-meeting-times__cell">
        <dt>Occurred</dt>
        <dd>
          <time datetime={occurred!.start}>{fmtDateTime(occurred!.start)}</time>
          {occurred!.start && occurred!.end ? ' – ' : ''}
          <time datetime={occurred!.end}>{fmtDateTime(occurred!.end)}</time>
        </dd>
      </div>
    )}
  </dl>
) : null}

<style>
.edoxen-meeting-times {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.75rem;
  margin: 0;
  font-size: 0.9375rem;
}
@media (min-width: 40rem) {
  .edoxen-meeting-times {
    grid-template-columns: 1fr 1fr;
  }
}
.edoxen-meeting-times__cell {
  padding: 0.75rem 1rem;
  border: 1px solid var(--edoxen-color-border);
  border-radius: var(--edoxen-radius-sm);
  background: var(--edoxen-color-surface);
}
.edoxen-meeting-times__cell dd {
  margin: 0.25rem 0 0;
  color: var(--edoxen-color-text);
  font-variant-numeric: tabular-nums;
}
</style>
