---
import type { MeetingListItem } from '../../data/index.js'
import MeetingCard from './MeetingCard.astro'

interface Props {
  items: readonly MeetingListItem[]
  compact?: boolean
  lang?: string
  urlPrefix?: string
}
const { items, compact = false, lang = 'en', urlPrefix: prefix = '/' } = Astro.props
// Default: responsive card grid (meetings index). Compact: dense column.
const listClass = compact
  ? 'edoxen-meeting-list edoxen-meeting-list--compact'
  : 'edoxen-meeting-list edoxen-card-grid'
---

{items.length === 0 ? (
  <p class="edoxen-empty">No meetings.</p>
) : (
  <ul class={listClass}>
    {items.map((m) => (
      <MeetingCard item={m} lang={lang} urlPrefix={prefix} />
    ))}
  </ul>
)}

<style>
.edoxen-meeting-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.edoxen-meeting-list--compact {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.edoxen-meeting-list--compact :global(.edoxen-meeting-card) {
  padding: 0.625rem 1rem;
}
</style>
