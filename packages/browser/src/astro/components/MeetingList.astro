---
import type { MeetingListItem } from '../../data/index.js'
import { pickLocalizedValue } from '../../i18n/index.js'

interface Props {
  items: readonly MeetingListItem[]
  compact?: boolean
  lang?: string
  urlPrefix?: string
}
const { items, compact = false, lang = 'en', urlPrefix: prefix = '/' } = Astro.props
const listClass = compact ? 'edoxen-meeting-list edoxen-meeting-list--compact' : 'edoxen-meeting-list'
---

{items.length === 0 ? (
  <p class="edoxen-empty">No meetings.</p>
) : (
  <ul class={listClass}>
    {items.map((m) => (
      <li class="edoxen-meeting-list__item">
        <a href={`${prefix}meetings/${encodeURIComponent(m.urn)}`}>{pickLocalizedValue(m.title, lang, m.urn)}</a>
        {!compact && (
          <dl class="edoxen-meeting-list__meta">
            <dt>URN</dt>
            <dd><code>{m.urn}</code></dd>
            {m.startDate && <><dt>Start</dt><dd>{m.startDate}</dd></>}
            {m.city && <><dt>Venue</dt><dd>{m.city}{m.countryCode && ` (${m.countryCode})`}</dd></>}
            {m.bodyType && <><dt>Body</dt><dd>{m.bodyType}</dd></>}
          </dl>
        )}
      </li>
    ))}
  </ul>
)}

<style>
.edoxen-meeting-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.edoxen-meeting-list__item {
  padding: 0.875rem 1.125rem;
  border: 1px solid var(--edoxen-color-border);
  border-radius: var(--edoxen-radius-sm);
  background: var(--edoxen-color-surface);
  box-shadow: var(--edoxen-shadow-sm, 0 1px 2px rgb(28 25 23 / 0.05));
  transition: border-color 150ms ease, box-shadow 150ms ease,
    transform 150ms ease;
}
.edoxen-meeting-list__item:hover {
  border-color: color-mix(in srgb, var(--edoxen-color-accent) 55%, var(--edoxen-color-border));
  box-shadow: var(--edoxen-shadow-md, 0 4px 12px rgb(28 25 23 / 0.08));
  transform: translateY(-1px);
}
.edoxen-meeting-list__item a {
  font-family: var(--edoxen-font-display, "Iowan Old Style",
    "Palatino Linotype", Palatino, Georgia, "Times New Roman", serif);
  font-size: 1.0625rem;
  font-weight: 600;
  color: var(--edoxen-color-primary);
}
.edoxen-meeting-list__item a:hover {
  color: var(--edoxen-color-accent);
  text-decoration: none;
}
.edoxen-meeting-list__meta {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 0.25rem 1rem;
  margin: 0.5rem 0 0;
  font-size: 0.8125rem;
  color: var(--edoxen-color-muted);
}
.edoxen-meeting-list__meta dd {
  margin: 0;
}
</style>
