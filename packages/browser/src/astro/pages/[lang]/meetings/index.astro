---
import cfg from 'virtual:edoxen-config'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import MeetingsIndex from '../../../components/MeetingsIndex.astro'
import { urlPrefix, t } from '../../../../i18n/index.js'

export function getStaticPaths() {
  return cfg.locales
    .filter((l) => (l.routePrefix ?? '') !== '')
    .map((l) => ({ params: { lang: l.code } }))
}

const lang = Astro.params.lang ?? cfg.site.locale
const prefix = urlPrefix(cfg, lang)
---

<BaseLayout config={cfg} lang={lang} title={`${t('nav.meetings', lang, cfg.uiStrings, cfg.terminology)} — ${cfg.site.title}`}>
  <h1>{t('nav.meetings', lang, cfg.uiStrings, cfg.terminology)}</h1>

  {cfg.features.search && (
    <search-filter
      data-mode="meetings"
      data-endpoint={`${prefix}data/meetings.json`}
      data-base-path={`${prefix}meetings`}
      data-placeholder={t('search.placeholder', lang, cfg.uiStrings, cfg.terminology)}
      data-aria-label={t('search.ariaLabelMeetings', lang, cfg.uiStrings, cfg.terminology)}
      data-empty-label={t('search.empty', lang, cfg.uiStrings, cfg.terminology)}
      data-decisions-label={t('section.adoptedDecisions', lang, cfg.uiStrings, cfg.terminology)}
      data-virtual-label={t('meeting.virtual', lang, cfg.uiStrings, cfg.terminology)}
      data-group-year-label={t('search.groupYear', lang, cfg.uiStrings, cfg.terminology)}
      data-group-location-label={t('search.groupLocation', lang, cfg.uiStrings, cfg.terminology)}
      data-group-body-label={t('search.groupBody', lang, cfg.uiStrings, cfg.terminology)}
      data-show-more-label={t('search.showMore', lang, cfg.uiStrings, cfg.terminology)}
      data-page-size={cfg.features.pagination.enabled ? String(cfg.features.pagination.pageSize) : undefined}
    ></search-filter>
  )}

  <MeetingsIndex locale={lang} urlPrefix={prefix} />
</BaseLayout>
