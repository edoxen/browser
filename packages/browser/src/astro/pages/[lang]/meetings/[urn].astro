---
import cfg from 'virtual:edoxen-config'
import payloads from 'virtual:edoxen-payloads'
import MeetingLayout from '../../../layouts/MeetingLayout.astro'
import UrnBar from '../../../components/UrnBar.astro'
import BodyBadge from '../../../components/BodyBadge.astro'
import AgendaTable from '../../../components/AgendaTable.astro'
import ScheduleTable from '../../../components/ScheduleTable.astro'
import MinutesSection from '../../../components/MinutesSection.astro'
import MeetingTimes from '../../../components/MeetingTimes.astro'
import DeclarationList from '../../../components/DeclarationList.astro'
import { meetingJsonLd } from '../../../../seo/index.js'
import { pickLocalizedValue, t, urlPrefix } from '../../../../i18n/index.js'
import { resolveBody, resolveVenue } from '../../../../data/prepare.js'
import { urnToPath } from '../../../../urn.js'

export function getStaticPaths() {
  const urns = Object.keys(payloads.meetingByUrn)
  const nonDefault = cfg.locales.filter((l) => (l.routePrefix ?? '') !== '')
  return urns.flatMap((urn) =>
    nonDefault.map((loc) => ({
      params: { lang: loc.code, urn },
      props: { meeting: payloads.meetingByUrn[urn] },
    })),
  )
}

interface Props {
  meeting: typeof payloads.meetingByUrn[string]
}
const { meeting } = Astro.props
const locale = Astro.params.lang ?? cfg.site.locale
const prefix = urlPrefix(cfg, locale)
const title = pickLocalizedValue(meeting.title, locale, meeting.urn ?? '')
const officers = meeting.officers ?? []
const agenda = meeting.agenda
const minutes = meeting.minutes ?? []
const components = meeting.components ?? []
const linkedDecisions = payloads.decisionsByMeetingUrn[meeting.urn ?? ''] ?? []
const jsonld = meetingJsonLd(meeting, { siteUrl: cfg.site.url, siteTitle: cfg.site.title, defaultLocale: locale })
// Three-tier resolution: inline venue data → meeting-scoped local_ref →
// global venue register (ref). Falls back to the meeting's own city.
const rawVenue = (meeting.venues ?? [])[0]
const venue = rawVenue ? resolveVenue(rawVenue, meeting.venues, payloads.venueByUrn) : undefined
const venueName = venue ? pickLocalizedValue(venue.name, locale) : ''
const venueCity = venue?.city ?? meeting.city
const venueCountry = venue?.country_code ?? meeting.country_code
const committee = meeting.committee
  ? resolveBody(meeting.committee, meeting.bodies, payloads.bodyByCode)
  : undefined
const committeeName = committee ? pickLocalizedValue(committee.name, locale) : ''
---

<MeetingLayout
  config={cfg}
  lang={locale}
  item={{
    urn: meeting.urn ?? '',
    identifier: (meeting.identifier[0]?.prefix ?? '') + '-' + (meeting.identifier[0]?.number ?? ''),
    title,
    startDate: meeting.scheduled_date_range?.start,
    endDate: meeting.scheduled_date_range?.end,
    bodyType: meeting.body_type,
    city: meeting.city,
    countryCode: meeting.country_code,
    status: meeting.status,
  }}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} is:inline />
  <UrnBar urn={meeting.urn ?? ''} />

  {(meeting.scheduled_date_range || meeting.occurred_date_range) && (
    <section>
      <h2>When</h2>
      <MeetingTimes scheduled={meeting.scheduled_date_range} occurred={meeting.occurred_date_range} />
    </section>
  )}

  {(meeting.declarations ?? []).length > 0 && (
    <section>
      <h2>Declarations</h2>
      <DeclarationList declarations={meeting.declarations ?? []} locale={locale} />
    </section>
  )}

  {meeting.body_type && <p><BodyBadge code={meeting.body_type} /></p>}

  {(venueName || venueCity) && (
    <section>
      <h2>Venue</h2>
      <p>{venueName || venueCity}{venueCountry ? `, ${venueCountry}` : ''}</p>
    </section>
  )}

  {committeeName && (
    <section>
      <h2>Committee</h2>
      <p>{committeeName}</p>
    </section>
  )}

  {officers.length > 0 && (
    <section>
      <h2>Officers</h2>
      <ul>
        {officers.map((o) => (
          <li>{o.role}{o.person?.name ? `: ${typeof o.person.name === 'string' ? o.person.name : o.person.name?.formatted ?? ''}` : ''}</li>
        ))}
      </ul>
    </section>
  )}

  {components.length > 0 && (
    <section>
      <h2>Schedule</h2>
      <ScheduleTable components={components} locale={locale} />
    </section>
  )}

  {agenda && agenda.items && agenda.items.length > 0 && (
    <section>
      <h2>Agenda</h2>
      <AgendaTable items={agenda.items} locale={locale} />
    </section>
  )}

  {minutes.length > 0 && (
    <section>
      <h2>Minutes</h2>
      {minutes.map((m) => (
        <MinutesSection minutes={m} locale={locale} />
      ))}
    </section>
  )}

  {linkedDecisions.length > 0 && (
    <section>
      <h2>{t('section.adoptedDecisions', locale, cfg.uiStrings)}</h2>
      <ul>
        {linkedDecisions.map((d) => (
          <li><a href={`${prefix}decisions/${urnToPath(d.urn)}`}>{pickLocalizedValue(d.title, locale, d.urn)}</a></li>
        ))}
      </ul>
    </section>
  )}

  {(meeting.source_urls ?? []).length > 0 && (
    <section>
      <h2>Source documents</h2>
      <ul>
        {(meeting.source_urls ?? []).map((s) => (
          <li><a href={s.ref}>{s.format ?? s.kind ?? 'document'}</a></li>
        ))}
      </ul>
    </section>
  )}
</MeetingLayout>
