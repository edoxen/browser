---
import cfg from 'virtual:edoxen-config'
import payloads from 'virtual:edoxen-payloads'
import BaseLayout from '../layouts/BaseLayout.astro'
import { t } from '../../i18n/index.js'

const lang = cfg.site.locale
const tt = (key: string): string => t(key, lang, cfg.uiStrings, cfg.terminology)

const decisionCount = payloads.decisionsList.items.length
const meetingCount = payloads.meetingsList.items.length

// 'about.using*' strings read 'Label — description'; the label gets the
// <strong>, the description follows the em-dash.
const usingItem = (key: string): { label: string; body: string } => {
  const [label, ...rest] = tt(key).split(' — ')
  return { label: label ?? '', body: rest.join(' — ') }
}
const using = [usingItem('about.usingDecisions'), usingItem('about.usingMeetings'), usingItem('about.usingUrns')]
---

<BaseLayout config={cfg} lang={lang} title={`${tt('about.title')} — ${cfg.site.title}`}>
  <h1>{tt('about.title')}</h1>

  <section>
    <h2>{cfg.site.title}</h2>
    <p>{cfg.site.description}</p>
    <dl class="edoxen-stats">
      <div><dt>{tt('about.stats.decisions')}</dt><dd>{decisionCount}</dd></div>
      <div><dt>{tt('about.stats.meetings')}</dt><dd>{meetingCount}</dd></div>
    </dl>
  </section>

  <section>
    <h2>{tt('about.format')}</h2>
    <p>{tt('about.formatBody')}</p>
  </section>

  <section>
    <h2>{tt('about.using')}</h2>
    <ul>
      {using.map((item) => (
        <li><strong>{item.label}</strong>{item.body ? ` — ${item.body}` : ''}</li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
.edoxen-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 1.5rem;
  margin: 1rem 0 0;
}
.edoxen-stats dd {
  margin: 0;
  font-size: 1.5rem;
  font-weight: 600;
}
.edoxen-stats dt {
  font-size: 0.85rem;
  color: var(--edoxen-color-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
</style>
