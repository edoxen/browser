---
import cfg from 'virtual:edoxen-config'
import payloads from 'virtual:edoxen-payloads'
import BaseLayout from '../layouts/BaseLayout.astro'
import { pickLocalizedValue, urlPrefix } from '../../i18n/index.js'
import { urnToPath } from '../../urn.js'

const lang = cfg.site.locale
const prefix = urlPrefix(cfg, lang)
const recentDecisions = payloads.decisionsList.items.slice(0, 5)
const recentMeetings = payloads.meetingsList.items.slice(0, 3)
---

<BaseLayout config={cfg} lang={lang}>
  <section class="edoxen-home-hero">
    <h1>{cfg.site.title}</h1>
    <p class="edoxen-home-hero__lede">{cfg.site.description}</p>
  </section>

  <section>
    <h2>Latest decisions</h2>
    <ul class="edoxen-recent-list">
      {recentDecisions.map((d) => (
        <li>
          <a href={`${prefix}decisions/${urnToPath(d.urn)}`}>{pickLocalizedValue(d.title, lang, d.urn)}</a>
          {d.bodyType && <span class="edoxen-badge">{d.bodyType}</span>}
        </li>
      ))}
    </ul>
  </section>

  {recentMeetings.length > 0 && (
    <section>
      <h2>Recent meetings</h2>
      <ul class="edoxen-recent-list">
        {recentMeetings.map((m) => (
          <li>
            <a href={`${prefix}meetings/${urnToPath(m.urn)}`}>{pickLocalizedValue(m.title, lang, m.urn)}</a>
            {m.startDate && <span class="edoxen-recent-list__date">{m.startDate}</span>}
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>

<style>
.edoxen-home-hero {
  padding-bottom: 0.5rem;
}
.edoxen-home-hero__lede {
  font-size: 1.1875rem;
  line-height: 1.6;
  color: var(--edoxen-color-muted);
  max-width: 62ch;
}
.edoxen-recent-list {
  list-style: none;
  padding: 0;
  margin: 0.5rem 0 0;
}
.edoxen-recent-list li {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin: 0;
  padding: 0.625rem 0;
  border-bottom: 1px solid var(--edoxen-color-border);
}
.edoxen-recent-list li:last-child {
  border-bottom: none;
}
.edoxen-recent-list a {
  font-family: var(--edoxen-font-display, "Iowan Old Style",
    "Palatino Linotype", Palatino, Georgia, "Times New Roman", serif);
  font-size: 1.0625rem;
  font-weight: 600;
  color: var(--edoxen-color-primary);
}
.edoxen-recent-list a:hover {
  color: var(--edoxen-color-accent);
  text-decoration: none;
}
.edoxen-recent-list__date {
  font-size: 0.8125rem;
  color: var(--edoxen-color-muted);
  font-variant-numeric: tabular-nums;
}
</style>
