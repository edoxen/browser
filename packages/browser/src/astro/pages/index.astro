---
import cfg from 'virtual:edoxen-config'
import BaseLayout from '../layouts/BaseLayout.astro'
import HomeContent from '../components/HomeContent.astro'
import { urlPrefix } from '../../i18n/index.js'

const lang = cfg.site.locale
const prefix = urlPrefix(cfg, lang)
---

<BaseLayout config={cfg} lang={lang}>
  <HomeContent locale={lang} urlPrefix={prefix} />
</BaseLayout>
