---
import BaseLayout from './BaseLayout.astro'
import type { EdoxenConfig } from '../../config/index.js'

// Thin shell: the record header (breadcrumb, badge row, localized title)
// lives in DecisionDetail so the root and [lang] routes share it.

interface LayoutItem {
  readonly urn: string
  readonly identifier: string
  readonly title: string
  readonly kind: string
  readonly dates: readonly { readonly type: string; readonly date: string }[]
  readonly bodyType?: string
}

interface Props {
  config: EdoxenConfig
  item: LayoutItem
  lang?: string
}
const { config, item, lang = config.site.locale } = Astro.props
const title = `${item.title} — ${config.site.title}`
---

<BaseLayout config={config} lang={lang} title={title} description={item.kind}>
  <article class="edoxen-decision">
    <slot />
  </article>
</BaseLayout>
