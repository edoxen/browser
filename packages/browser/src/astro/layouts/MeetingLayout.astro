---
import BaseLayout from './BaseLayout.astro'
import type { EdoxenConfig } from '../../config/index.js'
import { urlPrefix } from '../../i18n/index.js'

interface LayoutItem {
  readonly urn: string
  readonly identifier: string
  readonly title: string
  readonly startDate?: string
  readonly endDate?: string
  readonly bodyType?: string
  readonly city?: string
  readonly countryCode?: string
  readonly status?: string
}

interface Props {
  config: EdoxenConfig
  item: LayoutItem
  lang?: string
}
const { config, item, lang = config.site.locale } = Astro.props
const title = `${item.title} — ${config.site.title}`
const prefix = urlPrefix(config, lang)
---

<BaseLayout config={config} lang={lang} title={title} description={item.identifier}>
  <article class="edoxen-meeting">
    <a href={`${prefix}meetings`}>← Meetings</a>
    <h1>{item.title}</h1>
    {item.startDate && <p>{item.startDate}{item.endDate && ` – ${item.endDate}`}</p>}
    <slot />
  </article>
</BaseLayout>
