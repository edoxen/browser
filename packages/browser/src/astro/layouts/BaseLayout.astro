---
import type { EdoxenConfig } from '../../config/index.js'
import { generateCssTokens, resolveFooter } from '../../config/index.js'
import { urlPrefix } from '../../i18n/index.js'
import '../../../styles/base.css'
// Print styles are gated on features.printStyles: imported as a raw
// string and inlined only when the flag is on, so `false` omits the
// print CSS from the output entirely.
import printCss from '../../../styles/print.css?raw'
// Consumer override stylesheet (virtual: resolved to the consumer's
// theme.customCss path or <root>/src/styles/override.css when present,
// empty module otherwise). Imported after base.css so consumers win.
import 'virtual:edoxen-custom-css'

interface Props {
  config: EdoxenConfig
  title?: string
  description?: string
  lang?: string
}

const { config, title, description, lang = config.site.locale } = Astro.props
const pageTitle = title ?? config.site.title
const pageDescription = description ?? config.site.description
const tokens = generateCssTokens(config.theme)
const canonical = new URL(Astro.url.pathname, config.site.url).toString()
const prefix = urlPrefix(config, lang)
const navHref = (href: string): string => `${prefix}${href}`.replace(/\/{2,}/g, '/')
const footer = resolveFooter(config.site.title, config.footer)
// External stylesheet imports extracted from the consumer override
// (e.g. webfonts) — loaded as parallel head links so they never block
// the bundled CSS from applying (FOUC fix). Their URLs carry
// display=swap, so text paints immediately with fallbacks.
const customCssImports = (config as EdoxenConfig & { customCssImports?: string[] }).customCssImports ?? []
---

<!doctype html>
<html lang={lang} data-theme={config.features.darkMode ? 'auto' : 'light'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {config.features.darkMode && (
      // Set data-theme BEFORE first paint. Without this, the page paints
      // with light tokens and the theme-toggle island flips to dark only
      // after its JS hydrates — the dark-mode FOUC.
      <script is:inline>
        (function () {
          try {
            var stored = localStorage.getItem('edoxen-theme');
            var theme = (stored === 'light' || stored === 'dark')
              ? stored
              : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-theme', theme);
          } catch (e) {}
        })();
      </script>
    )}
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    {config.theme.logos.favicon && (
      <link rel="icon" href={config.theme.logos.favicon} />
    )}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />

    {customCssImports.map((href) => (
      <link rel="stylesheet" href={href} />
    ))}

    <style is:global set:html={tokens} />
    {config.features.printStyles && (
      <style is:global set:html={printCss} />
    )}
    <slot name="head" />
  </head>
  <body>
    <a href="#edoxen-content" class="edoxen-skip-link">Skip to content</a>
    <header class="edoxen-header">
      <a href={prefix} class="edoxen-header__brand">
        {config.theme.logos.primary && (
          <img src={config.theme.logos.primary} alt={config.site.title} />
        )}
        <span>{config.site.title}</span>
      </a>
      <nav class="edoxen-header__nav" aria-label="Primary">
        {config.nav.map((item) => (
          !item.locale || item.locale === lang
            ? <a href={navHref(item.href)}>{item.label}</a>
            : null
        ))}
      </nav>
      {config.features.darkMode && <theme-toggle></theme-toggle>}
    </header>
    <main class="edoxen-main" id="edoxen-content">
      <slot />
    </main>
    <footer class="edoxen-footer">
      {config.theme.logos.footer && (
        <img src={config.theme.logos.footer} alt="" />
      )}
      <ul class="edoxen-footer__social">
        {config.social.map((s) => (
          <li><a href={s.href}>{s.label}</a></li>
        ))}
      </ul>
      <p class="edoxen-footer__message" set:html={footer.message} />
      <p class="edoxen-footer__copyright">{footer.copyright}</p>
      {footer.showEdoxenAttribution && (
        <p class="edoxen-footer__attribution">
          Powered by <a href="https://edoxen.github.io">Edoxen</a>.
        </p>
      )}
    </footer>
    <script>
      import '../../islands/theme-toggle.ts'
      import '../../islands/urn-copy.ts'
      import '../../islands/search-filter.ts'
      import '../../islands/section-tabs.ts'
      import '../../islands/decade-scroller.ts'
      import '../../islands/print-button.ts'
      import '../../islands/reading-progress.ts'
    </script>
  </body>
</html>
